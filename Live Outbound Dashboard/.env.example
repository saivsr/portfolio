# ─────────────────────────────────────────────────────────────────────────
# Live Outbound Dashboard — environment template
# Copy to `.env` (ETL) / `.env.local` (web) and fill in real values.
# Every value here is a PLACEHOLDER. No real secret is committed.
# ─────────────────────────────────────────────────────────────────────────

# ── ETL (Python) — provided in production as GitHub Actions repo secrets ──
PV_API_KEY=PLUSVIBE_API_KEY_XXX
SUPABASE_PASSWORD=SUPABASE_DB_PASSWORD_XXX
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T_XXX/B_XXX/XXXXXXXXXXXX

# Optional ETL connection overrides (defaults live in etl/db.py, redacted there).
SUPABASE_HOST=aws-1-REGION.pooler.supabase.com
SUPABASE_USER=postgres.PROJECT_REF_XXX
SUPABASE_DB=postgres
SUPABASE_PORT=5432

# ── Web (Next.js) ──
NEXT_PUBLIC_SUPABASE_URL=https://PROJECT_REF_XXX.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=SUPABASE_ANON_KEY_XXX          # public, RLS-scoped read key
SUPABASE_SERVICE_ROLE_KEY=SUPABASE_SERVICE_ROLE_KEY_XXX      # server-only — NEVER expose to the browser
DASHBOARD_PASSWORD=CHOOSE_A_STRONG_PASSWORD_XXX             # gate; middleware fails closed if unset in prod
